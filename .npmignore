# npm pack uses "files" in package.json as the whitelist; this file
# excludes only from that list. Do not add paths that must be published.

# Dependencies and env
node_modules
.env
.npmrc

# Development / IDE
.git
.gitignore
.github
.vscode
.idea
*.log
*.md.bak

# Tests and scripts (not needed at runtime)
test/
scripts/
*.test.ts
jest.config.js
tsconfig.json
rollup.config.mjs

# Docs (optional: remove if you want to ship docs/)
# docs/

# Build artifacts that are regenerated
# dist/ is in "files" and is built by prepublishOnly — keep it
